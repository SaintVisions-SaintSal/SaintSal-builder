{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "URL to the user's profile photo" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A SaintSal Studio project",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the project" },
        "name": { "type": "string", "description": "Name of the project" },
        "ownerId": { "type": "string", "description": "UID of the user who owns this project" },
        "files": { "type": "object", "description": "Map of file paths to file contents and metadata" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the project was last updated" }
      },
      "required": ["id", "name", "ownerId", "files"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "SaintSal Studio projects"
    }
  }
}
